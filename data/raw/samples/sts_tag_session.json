{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "sts:AssumeRole",
        "sts:TagSession"
      ],
      "Resource": "arn:aws:iam::123456789012:role/TaggedRole",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Project": "MyProject"
        }
      }
    }
  ]
}