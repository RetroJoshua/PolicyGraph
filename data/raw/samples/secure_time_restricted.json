{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::work-bucket/*",
      "Condition": {
        "DateGreaterThan": {
          "aws:CurrentTime": "2026-01-01T09:00:00Z"
        },
        "DateLessThan": {
          "aws:CurrentTime": "2026-12-31T17:00:00Z"
        }
      }
    }
  ]
}