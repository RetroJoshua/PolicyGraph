{
  "source": "raw_e97be4f9c364.tf",
  "resource_type": "heredoc",
  "resource_name": "unknown",
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "ecs:RunTask"
        ],
        "Resource": [
          "${aws_ecs_task_definition.snowalert_runner.arn}"
        ],
        "Condition": {
          "ArnLike": {
            "ecs:cluster": "${aws_ecs_cluster.snowalert_cluster.arn}"
          }
        }
      },
      {
        "Effect": "Allow",
        "Action": "iam:PassRole",
        "Resource": [
          "*"
        ],
        "Condition": {
          "StringLike": {
            "iam:PassedToService": "ecs-tasks.amazonaws.com"
          }
        }
      }
    ]
  }
}