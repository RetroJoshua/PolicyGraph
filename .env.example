# PolicyGraph Environment Variables
# Copy this file to .env and fill in your values

# Device configuration
DEVICE=cpu
# Options: cpu, cuda, mps (for Mac)

# Model paths
MODEL_PATH=checkpoints/best_model.pt
CHECKPOINT_DIR=checkpoints

# Data configuration
DATA_DIR=data/raw/samples
LABELS_FILE=data/raw/samples/LABELS.json
PROCESSED_DATA_DIR=data/processed

# Training configuration
LEARNING_RATE=0.001
WEIGHT_DECAY=0.0001
BATCH_SIZE=16
EPOCHS=200
EARLY_STOPPING_ENABLED=true
EARLY_STOPPING_PATIENCE=50

# Model architecture
MODEL_IN_DIM=6
MODEL_HIDDEN_DIM=64
MODEL_NUM_LAYERS=3
MODEL_NUM_HEADS=4
MODEL_DROPOUT=0.2

# Analysis configuration
RISK_THRESHOLD=0.3

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Results output
RESULTS_DIR=results
REPORT_PATH=results/evaluation_report.json

# Testing
TEST_SEED=42

# AWS Configuration (if using with AWS accounts)
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Development
DEBUG=false
VERBOSE=false
